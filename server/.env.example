PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/hospital_hrm
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long-here
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long-here
CLIENT_ORIGIN=http://localhost:5173

# Optional Ethereum anchoring (Infura URL includes your project id).
# If BOTH variables below are set, new blocks MUST anchor on-chain or the API returns 502.
# Leave either empty to use local integrity hashes only (no Infura / no gas).
# For testing use Sepolia RPC + faucet ETH instead of mainnet.
ETHEREUM_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID
# Wallet private key (0x + 64 hex) that pays gas — NOT your Infura key. server/.env only (gitignored).
ETHEREUM_PRIVATE_KEY=
